# Copy into Vercel → Project → Settings → Environment Variables.
# Do not commit real secrets.

# Upstash Redis → database → REST API tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: if you created Upstash via Vercel Storage integration, these may exist instead:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
